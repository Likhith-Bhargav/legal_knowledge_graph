# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123
NEO4J_DATABASE=neo4j
NEO4J_MAX_POOL_SIZE=50

# ── LLM Provider ─────────────────────────────────────────────────────
# Set LLM_PROVIDER to one of: openai | anthropic | gemini
# Only the API key for the active provider needs to be filled in.
# ─────────────────────────────────────────────────────────────────────

LLM_PROVIDER=openai
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ── OpenAI ────────────────────────────────────────────────────────────
# Models: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-your-openai-key-here

# ── Anthropic ─────────────────────────────────────────────────────────
# To use: set LLM_PROVIDER=anthropic and fill in ANTHROPIC_API_KEY
# Models: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── Google Gemini ─────────────────────────────────────────────────────
# To use: set LLM_PROVIDER=gemini and fill in GEMINI_API_KEY
# Models: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
# Get your key at: https://aistudio.google.com/app/apikey
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash
# GEMINI_API_KEY=AIza-your-gemini-key-here

# ── App ───────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
